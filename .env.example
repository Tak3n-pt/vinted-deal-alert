PROVIDER_TYPE=apify
AUTHORIZED_DATA_API_URL=https://your-authorized-provider.example/search
AUTHORIZED_DATA_API_KEY=replace-me
APIFY_TOKEN=replace-me
APIFY_ACTOR_ID=epicscrapers~vinted-search-scraper
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/replace-me
POLL_INTERVAL_SECONDS=900
PROVIDER_TIMEOUT_SECONDS=20
MAX_PRODUCTS_PER_SCAN=100
HEARTBEAT_EVERY_SCANS=4
DATABASE_PATH=./data/deals.sqlite
# Hosted deployments should set DATABASE_URL to use Postgres/Neon instead of local SQLite.
DATABASE_URL=
RUN_ON_START=true
DRY_RUN=false
DASHBOARD_PORT=3000
DASHBOARD_ADMIN_PASSWORD=change-this-password
DASHBOARD_COOKIE_SECURE=true
