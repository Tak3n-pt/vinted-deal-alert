PROVIDER_TYPE=apify
AUTHORIZED_DATA_API_URL=https://your-authorized-provider.example/search
AUTHORIZED_DATA_API_KEY=replace-me
APIFY_TOKEN=replace-me
APIFY_ACTOR_ID=epicscrapers~vinted-search-scraper
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/replace-me
POLL_INTERVAL_SECONDS=900
PROVIDER_TIMEOUT_SECONDS=20
MAX_PRODUCTS_PER_SCAN=100
HEARTBEAT_EVERY_SCANS=4
DATABASE_PATH=./data/deals.sqlite
# Hosted deployments should set DATABASE_URL to use Postgres/Neon instead of local SQLite.
DATABASE_URL=
RUN_ON_START=true
DRY_RUN=false
DASHBOARD_PORT=3000
DASHBOARD_ADMIN_PASSWORD=change-this-password
DASHBOARD_COOKIE_SECURE=true

# --- Multi-tenant (Discord OAuth) ---
# Discord application credentials. Create at https://discord.com/developers/applications
# Required OAuth2 redirect: https://app.bonoitec.com/api/auth/discord/callback
DISCORD_OAUTH_CLIENT_ID=
DISCORD_OAUTH_CLIENT_SECRET=
DISCORD_OAUTH_REDIRECT_URI=https://app.bonoitec.com/api/auth/discord/callback

# Public base URL where the dashboard is reachable. Used for OAuth + cookies.
PUBLIC_BASE_URL=https://app.bonoitec.com

# Beta gate. Comma-separated Discord snowflake IDs allowed to sign in.
# Leave empty to allow all sign-ups. Has no effect on admin-plan users.
BETA_DISCORD_IDS=

# Legacy password login. Set to "1" to keep /api/auth/login active in production
# alongside Discord OAuth (operator emergency access). Always enabled in dev.
LEGACY_PASSWORD_LOGIN=

# Encryption key for per-user Discord webhook URLs at rest. 32 random bytes,
# base64-encoded. Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
DASHBOARD_ENCRYPTION_KEY=

# Server-to-server sync from the Vercel/Stripe payment site.
# Must match BOT_SYNC_SECRET on the Vercel project.
BOT_SYNC_SECRET=
PRO_DAILY_APIFY_QUOTA=500
FREE_DAILY_APIFY_QUOTA=30
